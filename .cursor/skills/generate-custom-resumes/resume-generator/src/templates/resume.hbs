<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    {{{css}}}
  </style>
</head>
<body>
  <div class="resume">
    <header class="header">
      <h1 class="name">{{name}}</h1>
      <p class="contact-line">
        {{#if email}}{{email}}{{/if}}
        {{#if links.linkedin}}<span class="contact-sep">·</span><a href="{{links.linkedin}}">{{links.linkedin}}</a>{{/if}}
        {{#if links.github}}<span class="contact-sep">·</span><a href="{{links.github}}">{{links.github}}</a>{{/if}}
      </p>
      <hr class="header-rule">
    </header>

    {{#if introduction}}
    <section class="summary-section">
      <h2>Summary</h2>
      <div class="summary-text">
        {{#each (splitLines introduction)}}
          <p>{{{md this}}}</p>
        {{/each}}
      </div>
    </section>
    {{/if}}

    <section class="experience">
      <h2>Experience</h2>
      {{#each experiences}}
      <div class="company">
        <h3 class="company-name">{{company}}</h3>
        {{#each roles}}
        <div class="role">
          <div class="role-header">
            <span class="company-name-inline">{{../company}}</span>,
            <span class="role-title-inline">{{title}}</span>
          </div>
          <div class="role-period">
            {{period}}{{#if note}} ({{note}}){{/if}}
          </div>
          <ul class="role-bullets">
            {{#each bullets}}
            <li>{{{md this}}}</li>
            {{/each}}
          </ul>
        </div>
        {{/each}}
      </div>
      {{/each}}
    </section>

    <section class="education">
      <h2>Education</h2>
      {{#each education}}
      <div class="education-item">
        <h3>{{degree}}</h3>
        <p class="institution">{{institution}}</p>
        {{#if details}}
        <p class="details">{{details}}</p>
        {{/if}}
      </div>
      {{/each}}
    </section>

    <section class="skills">
      <h2>Skills</h2>
      {{#if skills.languages}}
      <p><strong>Languages:</strong> {{skills.languages}}</p>
      {{/if}}
      {{#if skills.frontend}}
      <p><strong>Frontend:</strong> {{skills.frontend}}</p>
      {{/if}}
      {{#if skills.backend}}
      <p><strong>Backend:</strong> {{skills.backend}}</p>
      {{/if}}
      {{#if skills.databases}}
      <p><strong>Databases:</strong> {{skills.databases}}</p>
      {{/if}}
      {{#if skills.testing}}
      <p><strong>Testing:</strong> {{skills.testing}}</p>
      {{/if}}
      {{#if skills.devops}}
      <p><strong>DevOps:</strong> {{skills.devops}}</p>
      {{/if}}
      {{#if skills.architecture}}
      <p><strong>Architecture:</strong> {{skills.architecture}}</p>
      {{/if}}
    </section>
  </div>
</body>
</html>
